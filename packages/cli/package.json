{
  "name": "spark-edge",
  "version": "0.1.1",
  "description": "Spark Edge CLI and Backend",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kelwSagashi/SparkEdge.git"
  },
  "bugs": {
    "url": "https://github.com/kelwSagashi/SparkEdge/issues"
  },
  "homepage": "https://github.com/kelwSagashi/SparkEdge#readme",
  "main": "dist/index",
  "types": "dist/index.d.ts",
  "scripts": {
    "clean": "rimraf dist .turbo release-artifacts",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "prepare-assets": "node ./scripts/prepare-assets.js",
    "package:release": "pnpm run prepare-assets && node ./scripts/build-release.js",
    "buildAndDev": "pnpm run build && pnpm run dev",
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=4096 concurrently -k -n \"TypeScript,Bun\" -c \"yellow.bold,cyan.bold\" \"pnpm watch\" \"bun --watch ./bin/spark-edge\"",
    "start": "run-script-os",
    "start:default": "cd bin && bun ./spark-edge",
    "start:windows": "cd bin && bun spark-edge",
    "watch": "cross-env NODE_OPTIONS=--max-old-space-size=4096 tsc-watch -p tsconfig.build.json --onCompilationComplete \"tsc-alias -p tsconfig.build.json\"",
    "build:binary": "pkg dist/index.js --target node20-linux-x64,node20-macos-arm64,node20-win-x64 --outdir release"
  },
  "pkg": {
    "assets": [
      "dist/**/*",
      "../../frontend/dist/**/*",
      "node_modules/**/*.node"
    ],
    "scripts": "dist/**/*.js"
  },
  "bin": {
    "spark-edge": "./bin/spark-edge"
  },
  "engines": {
    "node": ">=20.19 <= 24.x"
  },
  "files": [
    "bin",
    "dist"
  ],
  "devDependencies": {
    "@spark-edge/typescript-config": "workspace:*",
    "@types/adm-zip": "^0.5.8",
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "catalog:",
    "@types/express": "catalog:",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "catalog:",
    "@types/pg": "^8.20.0",
    "@types/socket.io": "^3.0.1",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsc-watch": "^7.2.0",
    "tsx": "catalog:",
    "typescript": "catalog:"
  },
  "dependencies": {
    "spark-edge-di": "workspace:*",
    "adm-zip": "^0.5.17",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.4.6",
    "bullmq": "^5.61.0",
    "cookie-parser": "^1.4.7",
    "cors": "catalog:",
    "csv-stringify": "^6.7.0",
    "dotenv": "catalog:",
    "express": "catalog:",
    "express-rate-limit": "^8.2.1",
    "fast-glob": "^3.3.3",
    "firebase-admin": "^13.8.0",
    "googleapis": "^171.4.0",
    "jsonpath-plus": "^10.4.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.1",
    "multer": "^2.1.1",
    "nanoid": "^5.1.9",
    "pg": "^8.20.0",
    "reflect-metadata": "catalog:",
    "spark-edge-core": "workspace:*",
    "spark-edge-db": "workspace:*",
    "uuid": "^13.0.0",
    "zod": "^4.1.12",
    "zod-class": "^0.0.18"
  }
}
