{
  "name": "spark-edge-db",
  "version": "0.1.2",
  "description": "Spark Edge Database Layer",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vitest run",
    "dev": "pnpm watch",
    "watch": "tsc -p tsconfig.build.json --watch",
    "build": "tsc -p tsconfig.build.json",
    "generate": "drizzle-kit generate:sqlite",
    "migrate": "drizzle-kit migrate:sqlite",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts",
    "start": "node dist/index.js"
  },
  "main": "dist/index.js",
  "module": "src/index.ts",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "dependencies": {
    "better-sqlite3": "^12.4.6",
    "drizzle-kit": "^0.31.6",
    "drizzle-orm": "^0.44.7",
    "nanoid": "^5.1.6"
  },
  "devDependencies": {
    "@spark-edge/typescript-config": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "catalog:",
    "bun-types": "^1.3.14",
    "ts-node-dev": "^2.0.0",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
