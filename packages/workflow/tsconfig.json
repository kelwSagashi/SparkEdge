{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Node",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "outDir": "dist",
        "rootDir": "src",
        "composite": true,
        "declaration": true,
        "declarationMap": true,
        "paths": {
            "@nmg8/workflow/*": [
                "./*"
            ]
        }
    },
    "include": [
        "src/**/*"
    ],
    "references": []
