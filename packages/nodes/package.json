{
  "name": "nmg8-nodes",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "test": "vitest run",
    "build": "pnpm run copy && tsc --build tsconfig.build.esm.json tsconfig.build.cjs.json",
    "watch": "pnpm run copy && tsc --build tsconfig.build.esm.json tsconfig.build.cjs.json --watch",
    "dev": "pnpm watch",
    "start": "node dist/cjs/index.js",
    "copy": "copyfiles -u 1 \"src/**/*.svg\" dist/"
  },
  "dependencies": {
    "@nmg8/di": "workspace:*",
    "nmg8-workflow": "workspace:*"
  },
  "devDependencies": {
    "@nmg8/typescript-config": "workspace:*",
    "copyfiles": "^2.4.1",
    "tsc-alias": "^1.8.16",
    "tsc-watch": "^7.2.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "types": "dist/esm/index.d.ts",
  "module": "dist/esm/index.js",
  "main": "dist/cjs/index.js",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./*": "./*"
  },
  "files": [
    "dist/**/*"
  ]
}