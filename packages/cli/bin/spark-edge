#!/usr/bin/env node
const fs = require("fs");
const path = require("path");
const os = require("os");

// 1. Relaunch with Bun if running under Node.js
if (!process.versions.bun) {
  const { spawnSync } = require("child_process");
  try {
    const fileArg = process.platform === "win32" ? `"${__filename}"` : __filename;
    const result = spawnSync("bun", [fileArg, ...process.argv.slice(2)], {
      stdio: "inherit",
      shell: true,
    });
    process.exit(result.status ?? 0);
  } catch (err) {
    console.error(
      "[spark-edge] Error: Bun is required to run Spark Edge. Please install Bun (https://bun.sh) and try again."
    );
    process.exit(1);
  }
  return;
}

// 2. Patch node:v8 startupSnapshot.isBuildingSnapshot for Bun compatibility
try {
  const v8 = require("node:v8");
  if (v8 && v8.startupSnapshot) {
    v8.startupSnapshot.isBuildingSnapshot = () => false;
  }
} catch (e) {
  // Ignore
}

console.log("[spark-edge-launcher] Starting launcher under Bun...");
console.log("[spark-edge-launcher] process.execPath:", process.execPath);
console.log("[spark-edge-launcher] __dirname:", __dirname);
console.log("[spark-edge-launcher] process.cwd():", process.cwd());

require("reflect-metadata");

const binaryDir = path.dirname(process.execPath);
const scriptDir = __dirname;
const rootCandidates = [
  scriptDir,
  path.resolve(scriptDir, ".."),
  path.resolve(scriptDir, "..", ".."),
  path.resolve(scriptDir, "..", "..", ".."),
  binaryDir,
  path.resolve(binaryDir, ".."),
  path.resolve(binaryDir, "..", ".."),
];

function findWorkDir() {
  // First try to find monorepo root
  for (const dir of rootCandidates) {
    if (!fs.existsSync(dir)) continue;
    if (fs.existsSync(path.join(dir, "pnpm-workspace.yaml"))) return dir;
  }
  
  // Fallbacks
  for (const dir of rootCandidates) {
    if (!fs.existsSync(dir)) continue;
    if (fs.existsSync(path.join(dir, "package.json"))) return dir;
    if (fs.existsSync(path.join(dir, "dist", "assets", "index.html")))
      return dir;
    if (fs.existsSync(path.join(dir, "frontend", "dist", "index.html")))
      return dir;
    if (fs.existsSync(path.join(dir, "public"))) return dir;
  }
  return binaryDir;
}

const packageRoot = findWorkDir();
console.log("[spark-edge-launcher] Package root resolved to:", packageRoot);
try {
  process.chdir(packageRoot);
} catch (error) {
  console.warn(
    "[spark-edge] could not change working directory to package root:",
    packageRoot,
    error?.message || error,
  );
}

// 3. Set up SPARK_EDGE_DATA_DIR
if (!process.env.SPARK_EDGE_DATA_DIR) {
  if (fs.existsSync(path.join(packageRoot, "pnpm-workspace.yaml"))) {
    process.env.SPARK_EDGE_DATA_DIR = packageRoot;
  } else {
    process.env.SPARK_EDGE_DATA_DIR = path.join(os.homedir(), ".spark-edge");
  }
}
console.log("[spark-edge-launcher] Data directory set to:", process.env.SPARK_EDGE_DATA_DIR);

// 4. Set up SPARK_EDGE_MIGRATIONS_DIR
if (!process.env.SPARK_EDGE_MIGRATIONS_DIR) {
  const prodMigrations = path.join(packageRoot, "dist", "drizzle");
  const devMigrations = path.join(packageRoot, "packages", "cli", "dist", "drizzle");
  const dbMigrations = path.join(packageRoot, "packages", "db", "drizzle");
  
  if (fs.existsSync(prodMigrations)) {
    process.env.SPARK_EDGE_MIGRATIONS_DIR = prodMigrations;
  } else if (fs.existsSync(devMigrations)) {
    process.env.SPARK_EDGE_MIGRATIONS_DIR = devMigrations;
  } else if (fs.existsSync(dbMigrations)) {
    process.env.SPARK_EDGE_MIGRATIONS_DIR = dbMigrations;
  }
}
console.log("[spark-edge-launcher] Migrations directory set to:", process.env.SPARK_EDGE_MIGRATIONS_DIR);

process.on("uncaughtException", (error) => {
  console.error("[spark-edge] Uncaught exception:", error?.stack || error);
  waitForUserBeforeExit();
});

process.on("unhandledRejection", (reason) => {
  console.error("[spark-edge] Unhandled rejection:", reason);
  waitForUserBeforeExit();
});

async function main() {
  console.log("[spark-edge] Starting application...");
  const { Container } = await import("spark-edge-di");
  const { CommandRegistry } = await import("../dist/command-registry.js");
  await Container.get(CommandRegistry).execute();
}

main().catch((error) => {
  console.error("[spark-edge] Startup failed:", error?.stack || error);
  waitForUserBeforeExit();
});

function waitForUserBeforeExit() {
  if (process.platform !== "win32") {
    process.exit(1);
    return;
  }

  console.error("\n[spark-edge] Press Enter to exit...");
  process.stdin.resume();
  process.stdin.on("data", () => process.exit(1));
}
