{
  "name": "spark-edge-core",
  "version": "1.0.0",
  "description": "Spark Edge Core Engine",
  "scripts": {
    "test": "vitest run",
    "dev": "pnpm watch",
    "watch": "tsc-watch -p tsconfig.build.json --onCompilationComplete \"tsc-alias -p tsconfig.build.json\"",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node dist/index.js"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    },
    "./*": "./*"
  },
  "devDependencies": {
    "@spark-edge/typescript-config": "workspace:*",
    "@types/cors": "^2.8.19",
    "@types/lodash": "^4.17.20",
    "@types/lodash.get": "^4.4.9",
    "@types/socket.io": "^3.0.1",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsc-watch": "^7.2.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "bullmq": "^5.61.0",
    "cors": "^2.8.5",
    "fast-glob": "^3.3.3",
    "lodash": "^4.17.21",
    "spark-edge-db": "workspace:*",
    "p-cancelable": "^4.0.1"
  }
}


