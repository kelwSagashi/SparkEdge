{
  "extends": "../../tsconfig.common.json",
  "compilerOptions": {
    "lib": ["es2022"],
		"rootDir": ".",
		"baseUrl": "src",

    "paths": {
			"@/*": ["./*"],
		},

    "tsBuildInfoFile": "dist/typecheck.tsbuildinfo",
		"emitDecoratorMetadata": true,
		"experimentalDecorators": true,

		"useUnknownInCatchVariables": false
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [],
  "references": [
    { "path": "../workflow/tsconfig.build.esm.json" },
  ]
}