{
  "name": "nmg8",
  "version": "0.0.1",
  "description": "",
  "main": "dist/index",
  "types": "dist/index.d.ts",
  "scripts": {
    "clean": "rimraf dist .turbo",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "buildAndDev": "pnpm run build && pnpm run dev",
    "dev": "concurrently -k -n \"TypeScript,Node\" -c \"yellow.bold,cyan.bold\" \"pnpm watch\" \"nodemon\"",
    "start": "run-script-os",
    "start:default": "cd bin && ./nmg8",
    "start:windows": "cd bin && nmg8",
    "watch": "tsc-watch -p tsconfig.build.json --onCompilationComplete \"tsc-alias -p tsconfig.build.json\""
  },
  "bin": {
    "nmg8": "./bin/nmg8"
  },
  "engines": {
    "node": ">=20.19 <= 24.x"
  },
  "files": [
    "bin",
    "dist"
  ],
  "devDependencies": {
    "@nmg8/typescript-config": "workspace:*",
    "@types/cors": "^2.8.19",
    "@types/socket.io": "^3.0.1",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsc-watch": "^7.2.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@nmg8/di": "workspace:*",
    "bullmq": "^5.61.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "fast-glob": "^3.3.3",
    "nmg8-core": "workspace:*",
    "nmg8-db": "workspace:*",
    "nmg8-nodes": "workspace:*",
    "nmg8-workflow": "workspace:*",
    "zod": "^4.1.12",
    "zod-class": "^0.0.18"
  }
}
