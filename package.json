{
  "name": "spark-edge-monorepo",
  "version": "1.0.1",
  "description": "Spark Edge - Advanced Monitoring & Manager",
  "main": "index.js",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo run dev --parallel",
    "start": "bun ./packages/cli/bin/spark-edge",
    "predev": "pnpm -w run db:migrate && pnpm -w run db:seed",
    "prestart": "pnpm -w run db:migrate",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:seed": "turbo db:seed",
    "release": "pnpm run build && pnpm --filter spark-edge run package:release",
    "prepare-assets": "pnpm --filter spark-edge run prepare-assets",
    "publish:all": "pnpm -r publish --access public --no-git-checks"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kelwSagashi/SparkEdge.git"
  },
  "keywords": [
    "monitoring",
    "automation",
    "spark-edge"
  ],
  "author": "KelwSagashi",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/kelwSagashi/SparkEdge/issues"
  },
  "homepage": "https://github.com/kelwSagashi/SparkEdge#readme",
  "private": true,
  "engines": {
    "node": ">=22.16",
    "pnpm": ">=10.20.0"
  },
  "packageManager": "pnpm@10.22.0",
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@spark-edge/typescript-config": "workspace:*",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "ansi-regex": "^5.0.1",
      "ansi-styles": "^4.3.0",
      "better-sqlite3": "^12.4.1",
      "chalk": "^4.1.2",
      "cliui": "^8.0.1",
      "color-convert": "^2.0.1",
      "color-name": "^1.1.4",
      "emoji-regex": "^8.0.0",
      "escalade": "^3.2.0",
      "get-caller-file": "^2.0.5",
      "has-flag": "^4.0.0",
      "is-fullwidth-code-point": "^3.0.0",
      "re-resizable": "^6.11.2",
      "react-draggable": "^4.5.0",
      "require-directory": "^2.1.1",
      "rxjs": "^7.8.2",
      "shell-quote": "^1.8.3",
      "string-width": "^4.2.3",
      "strip-ansi": "^6.0.1",
      "supports-color": "^8.1.1",
      "tree-kill": "^1.2.2",
      "tslib": "^2.8.1",
      "wrap-ansi": "^7.0.0",
      "y18n": "^5.0.8",
      "yargs": "^17.7.2",
      "yargs-parser": "^21.1.1"
    },
    "onlyBuiltDependencies": [
      "@firebase/util",
      "better-sqlite3",
      "esbuild",
      "msgpackr-extract",
      "protobufjs"
    ]
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "reflect-metadata": "catalog:",
    "run-script-os": "^1.1.6"
  }
}
