{
  "name": "spark-edge-core",
  "version": "0.1.2",
  "description": "Spark Edge Core Engine",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vitest run",
    "dev": "pnpm watch",
    "watch": "tsc-watch -p tsconfig.build.json --onCompilationComplete \"tsc-alias -p tsconfig.build.json\"",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node dist/index.js"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    },
    "./*": "./*"
  },
  "devDependencies": {
    "@spark-edge/typescript-config": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "catalog:",
    "@types/lodash": "^4.17.20",
    "@types/lodash.get": "^4.4.9",
    "@types/node": "catalog:",
    "@types/socket.io": "^3.0.1",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsc-watch": "^7.2.0",
    "tsx": "catalog:",
    "typescript": "catalog:"
  },
  "dependencies": {
    "@types/js-yaml": "^4.0.9",
    "bullmq": "^5.61.0",
    "cors": "catalog:",
    "fast-glob": "^3.3.3",
    "js-yaml": "^5.2.0",
    "lodash": "^4.17.21",
    "mqtt": "^5.15.1",
    "p-cancelable": "^4.0.1",
    "spark-edge-db": "workspace:*",
    "uuid": "^13.0.0"
  }
}
