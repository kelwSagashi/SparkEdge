{
	"extends": ["./tsconfig.json", "@nmg8/typescript-config/modern/tsconfig.cjs.json"],
	"compilerOptions": {
		"outDir": "dist",
		"module": "commonjs",
		"tsBuildInfoFile": "dist/typecheck.tsbuildinfo"
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.json",
		"src/**/*.svg",
	],
	"exclude": [
		"node_modules",
		"nodes/**/*.test.ts"
	]
}