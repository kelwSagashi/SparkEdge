{
  "name": "nmg8-nodes",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "build": "tsc --build tsconfig.build.cjs.json && tsc-alias -p tsconfig.build.cjs.json && pnpm run copy",
    "watch": "tsc-watch -p tsconfig.build.cjs.json --onCompilationComplete \"tsc-alias -p tsconfig.build.cjs.json && pnpm run copy\"",
    "dev": "pnpm watch",
    "start": "node dist/cjs/index.js",
    "copy": "copyfiles -u 1 \"src/**/*.svg\" dist/"
  },
  "dependencies": {
    "@nmg8/di": "workspace:*",
    "nmg8-workflow": "workspace:*"
  },
  "devDependencies": {
    "@nmg8/typescript-config": "workspace:*",
    "copyfiles": "^2.4.1",
    "tsc-alias": "^1.8.16",
    "tsc-watch": "^7.2.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist"
  ]
}