SPARK_CLOUD_URL=https://
SPARK_EDGE_API_URL=http:///api
JWT_SECRET=dev-secret

# MQTT_URL is kept for convenience but SparkEdge now reads broker URL from local DB
# (saved during pairing). This env var is only a fallback for dev without pairing.
MQTT_URL=mqtt://

# MQTT_USER and MQTT_PASS are intentionally REMOVED — each device has its own credentials
# Credentials are provisioned via POST /edges/pair or POST /devices/register

DB_FILE_NAME=packages/db/monitor.db

# EMQX Dashboard (optional — only needed when running docker-compose directly)
EMQX_DASHBOARD_USER=admin
EMQX_DASHBOARD_PASS=